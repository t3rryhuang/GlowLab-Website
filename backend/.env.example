# Copy this file to .env and paste your real key.
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

# The current Google quickstart examples use gemini-3-flash-preview.
# If that model is not available on your account, try gemini-2.5-flash.
GEMINI_MODEL=gemini-3-flash-preview

# Local backend port
PORT=3000
